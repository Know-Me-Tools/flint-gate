# Flint Gate environment variables
# Copy to .env and configure for your environment

# Log level (default: info,flint_gate=debug)
RUST_LOG=info,flint_gate=debug

# Config file path (default: config.yaml)
FLINT_GATE_CONFIG=config.yaml

# Postgres connection URL (overrides database.url in config.yaml)
DATABASE_URL=postgres://flintgate:secret@localhost:5432/flintgate
