# ─────────────────────────────────────────────────────────────────────────────
# Flint Gate — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# Proxy server listen address (overrides server.listen in config.yaml)
# FLINT_GATE_LISTEN=0.0.0.0:4456

# Admin API listen address (overrides server.admin_listen in config.yaml)
# FLINT_GATE_ADMIN_LISTEN=0.0.0.0:4457

# Path to config.yaml (default: config.yaml in working directory)
# FLINT_GATE_CONFIG=config.yaml

# Logging filter (EnvFilter syntax)
RUST_LOG=info,flint_gate=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string (overrides database.url in config.yaml).
# Leave empty to run without database features (no API key store, no usage logging).
DATABASE_URL=postgres://flintgate:flintgate@localhost:5432/flintgate

# ── JWT Signing ───────────────────────────────────────────────────────────────
# HMAC secret for HS256. Use signing_key_path for RS256/ES256 in production.
# Overrides jwt.signing_key_secret in config.yaml.
FLINT_GATE_JWT_SECRET=change-me-in-production-use-a-strong-random-secret

# Path to PEM private key for RS256/ES256.
# FLINT_GATE_JWT_KEY_PATH=/etc/flint-gate/keys/private.pem

# ── Docker Compose ────────────────────────────────────────────────────────────
# Override host ports when running via docker-compose.
# PROXY_PORT=4456
# ADMIN_PORT=4457
# POSTGRES_PORT=5432

# Postgres password used by both flint-gate and postgres containers.
POSTGRES_PASSWORD=flintgate
